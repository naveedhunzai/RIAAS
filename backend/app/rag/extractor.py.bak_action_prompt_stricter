import json
import re
from typing import Any

from backend.app.rag.ollama_client import ollama_generate


def _escape_control_chars_in_strings(s: str) -> str:
    result = []
    in_string = False
    escape = False

    for ch in s:
        if escape:
            result.append(ch)
            escape = False
            continue

        if ch == "\\":
            result.append(ch)
            escape = True
            continue

        if ch == '"':
            result.append(ch)
            in_string = not in_string
            continue

        if in_string:
            if ch == "\n":
                result.append("\\n")
                continue
            if ch == "\r":
                result.append("\\r")
                continue
            if ch == "\t":
                result.append("\\t")
                continue

        result.append(ch)

    return "".join(result)


def _extract_json(text: str) -> Any:
    """
    Robust-ish JSON extraction: tries to find the first JSON array in the response.
    Also repairs invalid control characters that LLMs sometimes emit inside strings.
    """
    match = re.search(r"\[.*\]", text, flags=re.DOTALL)
    if not match:
        raise ValueError("No JSON array found in model output.")

    raw_json = match.group(0)

    # Remove disallowed low ASCII control chars first
    raw_json = re.sub(r"[\x00-\x08\x0B\x0C\x0E-\x1F]", "", raw_json)

    try:
        return json.loads(raw_json)
    except json.JSONDecodeError:
        repaired = _escape_control_chars_in_strings(raw_json)
        return json.loads(repaired)


# ---- Normalization guards (TOP-LEVEL) ----

ALLOWED_MODALITIES = {"MUST", "SHALL", "PROHIBITED", "SHOULD"}
ALLOWED_CATEGORIES = {"Reporting", "Recordkeeping", "Training", "Monitoring", "Governance", "Other"}

CATEGORY_MAP = {
    # model outputs â†’ your taxonomy
    "Prevention": "Monitoring",
    "Detective": "Monitoring",
    "Detection": "Monitoring",
    "Controls": "Monitoring",
    "Security": "Monitoring",
    "Policy": "Governance",
    "Policies": "Governance",
    "Procedure": "Governance",
    "Procedures": "Governance",
    "Oversight": "Governance",
    "Compliance": "Governance",
    "Documentation": "Recordkeeping",
    "Records": "Recordkeeping",
    "Reporting Requirements": "Reporting",
    "Report": "Reporting",
    "Training Requirements": "Training",
}

def normalize_modality(m: str | None) -> str:
    """
    Convert model modality to one of:
    MUST, SHALL, PROHIBITED, SHOULD
    """
    m = (m or "").upper().strip()

    # map common variants
    if m in {"REQUIRED", "MANDATORY"}:
        return "MUST"
    if m in {"MAY NOT", "MUST NOT"}:
        return "PROHIBITED"
    if m in {"RECOMMENDED", "ADVISORY"}:
        return "SHOULD"

    return m if m in ALLOWED_MODALITIES else "SHOULD"


def normalize_category(c: str | None) -> str:
    """
    Convert model category to one of:
    Reporting, Recordkeeping, Training, Monitoring, Governance, Other
    """
    c = (c or "").strip()
    if not c:
        return "Other"

    c_title = c.title()
    mapped = CATEGORY_MAP.get(c_title, c_title)

    return mapped if mapped in ALLOWED_CATEGORIES else "Other"


# ---- Requirement extraction ----

def extract_requirements_from_context(question: str, contexts: list[str], model: str = "gemma3:1b") -> list[dict]:
    prompt = (
        "You extract compliance REQUIREMENTS from regulatory text.\n"
        "Return ONLY valid JSON as a single JSON array. No markdown. No code fences. No commentary.\n\n"
        "Strict rules:\n"
        "- Return at most 8 objects.\n"
        "- Each object must be on one line conceptually and every string value must be a single line.\n"
        "- Do NOT include any newline, carriage return, or tab inside requirement_text or any JSON value.\n"
        "- If a candidate item is too long, rewrite it as one short complete sentence.\n"
        "- If unsure, omit the item.\n"
        "- Do NOT truncate any string.\n"
        "- Extract ONLY explicit obligations or prohibitions supported by the source text.\n"
        "- requirement_text must be concise, complete, and plain text.\n"
        "- modality must be exactly one of: MUST, SHALL, PROHIBITED, SHOULD.\n"
        "- category must be exactly one of: Reporting, Recordkeeping, Training, Monitoring, Governance, Other.\n"
        "- citation_id must match the source block number where it came from.\n\n"
        "Valid JSON schema:\n"
        "[\n"
        "  {\"requirement_text\":\"One single-line sentence.\",\"modality\":\"MUST\",\"category\":\"Governance\",\"citation_id\":1}\n"
        "]\n\n"
        "Invalid output examples:\n"
        "- markdown fences\n"
        "- explanatory text before or after JSON\n"
        "- multiline strings\n"
        "- modality values like MUST|SHALL|PROHIBITED|SHOULD\n"
        "- category values like Governance|Other\n\n"
        f"REQUIREMENT:\n{requirement_text}\n\n"
        "SOURCES:\n" + "\n\n".join(contexts) + "\n\n"
        "JSON:"
    )

    raw = ollama_generate(prompt, model=model)
    print("\n=== RAW REQUIREMENT EXTRACTION OUTPUT START ===")
    print(raw)
    print("=== RAW REQUIREMENT EXTRACTION OUTPUT END ===\n")
    data = _extract_json(raw)

    cleaned: list[dict] = []
    for item in data:
        if not isinstance(item, dict):
            continue

        rt = (item.get("requirement_text") or "").strip()
        if not rt:
            continue

        cleaned.append({
            "requirement_text": rt,
            "modality": normalize_modality(item.get("modality")),
            "category": normalize_category(item.get("category")),
            "citation_id": int(item.get("citation_id") or 0) or None,
        })

    return cleaned


# ---- Action extraction ----

def extract_actions_for_requirement(requirement_text: str, model: str = "gemma3:1b") -> list[dict]:
    prompt = (
        "You convert a compliance requirement into actionable remediation tasks.\n"
        "Return ONLY valid JSON as a list. No markdown. No code fences. No commentary.\n\n"
        "Rules:\n"
        "- Return 1 to 5 actions.\n"
        "- Each action must be practical and specific.\n"
        "- Every string value must be a single line.\n"
        "- priority must be exactly one of: Low, Medium, High.\n\n"
        "JSON schema:\n"
        "[\n"
        "  {\"action_text\":\"...\",\"evidence_needed\":\"...\",\"owner_role\":\"...\",\"priority\":\"Low|Medium|High\"}\n"
        "]\n\n"
        f"REQUIREMENT:\n{requirement_text}\n\n"
        "JSON:"
    )

    raw = ollama_generate(prompt, model=model)
    print("\n=== RAW REQUIREMENT EXTRACTION OUTPUT START ===")
    print(raw)
    print("=== RAW REQUIREMENT EXTRACTION OUTPUT END ===\n")
    data = _extract_json(raw)

    cleaned = []
    for item in data:
        if not isinstance(item, dict):
            continue
        at = (item.get("action_text") or "").strip()
        if not at:
            continue
        cleaned.append({
            "action_text": at,
            "evidence_needed": (item.get("evidence_needed") or "").strip() or None,
            "owner_role": (item.get("owner_role") or "").strip() or None,
            "priority": (item.get("priority") or "Medium").strip(),
        })
    return cleaned









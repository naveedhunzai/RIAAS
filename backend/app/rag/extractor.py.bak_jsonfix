import json
import re
from typing import Any

from backend.app.rag.ollama_client import ollama_generate


def _extract_json(text: str) -> Any:
    """
    Robust-ish JSON extraction: tries to find the first JSON array in the response.
    Also strips invalid control characters that LLMs sometimes emit inside strings.
    """
    match = re.search(r"\[.*\]", text, flags=re.DOTALL)
    if not match:
        raise ValueError("No JSON array found in model output.")

    raw_json = match.group(0)

    # Remove ASCII control characters except standard whitespace
    raw_json = re.sub(r"[\x00-\x08\x0B\x0C\x0E-\x1F]", "", raw_json)

    return json.loads(raw_json)


# ---- Normalization guards (TOP-LEVEL) ----

ALLOWED_MODALITIES = {"MUST", "SHALL", "PROHIBITED", "SHOULD"}
ALLOWED_CATEGORIES = {"Reporting", "Recordkeeping", "Training", "Monitoring", "Governance", "Other"}

CATEGORY_MAP = {
    # model outputs â†’ your taxonomy
    "Prevention": "Monitoring",
    "Detective": "Monitoring",
    "Detection": "Monitoring",
    "Controls": "Monitoring",
    "Security": "Monitoring",
    "Policy": "Governance",
    "Policies": "Governance",
    "Procedure": "Governance",
    "Procedures": "Governance",
    "Oversight": "Governance",
    "Compliance": "Governance",
    "Documentation": "Recordkeeping",
    "Records": "Recordkeeping",
    "Reporting Requirements": "Reporting",
    "Report": "Reporting",
    "Training Requirements": "Training",
}

def normalize_modality(m: str | None) -> str:
    """
    Convert model modality to one of:
    MUST, SHALL, PROHIBITED, SHOULD
    """
    m = (m or "").upper().strip()

    # map common variants
    if m in {"REQUIRED", "MANDATORY"}:
        return "MUST"
    if m in {"MAY NOT", "MUST NOT"}:
        return "PROHIBITED"
    if m in {"RECOMMENDED", "ADVISORY"}:
        return "SHOULD"

    return m if m in ALLOWED_MODALITIES else "SHOULD"


def normalize_category(c: str | None) -> str:
    """
    Convert model category to one of:
    Reporting, Recordkeeping, Training, Monitoring, Governance, Other
    """
    c = (c or "").strip()
    if not c:
        return "Other"

    c_title = c.title()
    mapped = CATEGORY_MAP.get(c_title, c_title)

    return mapped if mapped in ALLOWED_CATEGORIES else "Other"


# ---- Requirement extraction ----

def extract_requirements_from_context(question: str, contexts: list[str], model: str = "gemma3:1b") -> list[dict]:
    prompt = (
        "You extract compliance REQUIREMENTS from regulatory text.\n"
        "Return ONLY valid JSON as a list of objects. No extra text.\n\n"
        "Rules:\n"
        "- Extract ONLY explicit obligations/prohibitions from the sources.\n"
        "- Do NOT create generic controls like 'should implement procedures' unless the source explicitly says so.\n"
        "- Prefer MUST/SHALL/PROHIBITED when the source is mandatory; use SHOULD only if advisory.\n"
        "- requirement_text must be concise (1-2 sentences).\n"
        "- category must be one of: Reporting, Recordkeeping, Training, Monitoring, Governance, Other.\n"
        "- citation_id must match the source block number where it came from.\n\n"
        "JSON schema:\n"
        "[\n"
        "  {\"requirement_text\":\"...\",\"modality\":\"MUST|SHALL|PROHIBITED|SHOULD\","
        "\"category\":\"Reporting|Recordkeeping|Training|Monitoring|Governance|Other\",\"citation_id\":1}\n"
        "]\n\n"
        f"QUESTION/TOPIC:\n{question}\n\n"
        "SOURCES:\n" + "\n\n".join(contexts) + "\n\n"
        "JSON:"
    )

    raw = ollama_generate(prompt, model=model)
    data = _extract_json(raw)

    cleaned: list[dict] = []
    for item in data:
        if not isinstance(item, dict):
            continue

        rt = (item.get("requirement_text") or "").strip()
        if not rt:
            continue

        cleaned.append({
            "requirement_text": rt,
            "modality": normalize_modality(item.get("modality")),
            "category": normalize_category(item.get("category")),
            "citation_id": int(item.get("citation_id") or 0) or None,
        })

    return cleaned


# ---- Action extraction ----

def extract_actions_for_requirement(requirement_text: str, model: str = "gemma3:1b") -> list[dict]:
    prompt = (
        "You convert a compliance requirement into actionable remediation tasks.\n"
        "Return ONLY valid JSON as a list. No extra text.\n\n"
        "JSON schema:\n"
        "[\n"
        "  {\"action_text\":\"...\",\"evidence_needed\":\"...\",\"owner_role\":\"...\","
        "\"priority\":\"Low|Medium|High\"}\n"
        "]\n\n"
        f"REQUIREMENT:\n{requirement_text}\n\n"
        "JSON:"
    )

    raw = ollama_generate(prompt, model=model)
    data = _extract_json(raw)

    cleaned = []
    for item in data:
        if not isinstance(item, dict):
            continue
        at = (item.get("action_text") or "").strip()
        if not at:
            continue
        cleaned.append({
            "action_text": at,
            "evidence_needed": (item.get("evidence_needed") or "").strip() or None,
            "owner_role": (item.get("owner_role") or "").strip() or None,
            "priority": (item.get("priority") or "Medium").strip(),
        })
    return cleaned


